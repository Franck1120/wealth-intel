# === REQUIRED ===

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Data APIs (all free)
FRED_API_KEY=your-fred-api-key
COINGECKO_API_KEY=your-coingecko-demo-key

# Cron Security
CRON_SECRET=generate-a-random-secret-here

# === EMAIL (Brevo — free: 300/day) ===

BREVO_API_KEY=xkeysib-your-api-key
BREVO_SENDER_EMAIL=your-brevo-account-email@example.com
BREVO_SENDER_NAME=Wealth Intel

# === OPTIONAL ===

# ANTHROPIC_API_KEY=           # Only if you enable AI module ($2-5/month)
# UPSTASH_REDIS_REST_URL=      # Distributed rate limiting
